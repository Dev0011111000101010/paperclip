#!/bin/sh
# Reject AI-tool attribution trailers in commit messages.
# See AGENTS.md §5a "Git Commit Rules" for the full policy.
# Override only via --no-verify (requires explicit board/user approval per AGENTS.md §5a rule 4).

MSG_FILE="$1"

if LC_ALL=C grep -qiE '^Co-Authored-By:|Generated with \[Claude|Sent from.*Claude' "$MSG_FILE"; then
    echo "ERROR: Commit message contains a banned AI-tool attribution trailer." >&2
    echo "       Remove all Co-Authored-By: and 'Generated with' lines." >&2
    echo "       See AGENTS.md §5a for the full policy." >&2
    exit 1
fi

exit 0
